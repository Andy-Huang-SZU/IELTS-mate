{
  "name": "ielts-mate",
  "version": "0.1.0",
  "description": "AI-powered IELTS prep desktop app",
  "main": "out/main/index.js",
  "author": "IELTS-mate",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "bash scripts/dev-web.sh",
    "dev:web-only": "vite --config electron.vite.web.config.ts",
    "build": "electron-vite build",
    "build:backend": "cd backend && pyinstaller backend.spec --noconfirm --clean",
    "build:mac": "pnpm build && electron-builder --mac --config electron-builder.yml",
    "build:win": "pnpm build && electron-builder --win --config electron-builder.yml",
    "build:linux": "pnpm build && electron-builder --linux --config electron-builder.yml",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "axios": "^1.12.2",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "echarts": "^6.0.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.13.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "electron": "^37.4.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "eslint": "^9.35.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
